# ═══════════════════════════════════════════════════════════════
#  Money-Saver — Environment Variables Template
# ═══════════════════════════════════════════════════════════════
# Copy this file to `.env` and fill in the real values.
# NEVER commit `.env` to version control.
# ═══════════════════════════════════════════════════════════════

# ─── Turso Database ─────────────────────────────────────────
# Obtained from the Turso dashboard: https://turso.tech
TURSO_DATABASE_URL=<YOUR_TURSO_DATABASE_URL>
# Example: libsql://money-saver-your-org.turso.io

TURSO_AUTH_TOKEN=<YOUR_TURSO_AUTH_TOKEN>
# Example: eyJhbGciOiJFZERTQSIsInR5cCI6IkpXVCJ9.eyJp...

# ─── JWT Authentication ───────────────────────────────────────
# Used to sign and verify user authentication tokens.
# Generate a strong random string (at least 32 chars recommended):
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=<YOUR_STRONG_JWT_SECRET>

# ─── Optional: CoinGecko API ─────────────────────────────────
# Override the default CoinGecko API URL (optional).
# If not set, defaults to the public free-tier endpoint.
# VITE_COINGECKO_API_URL=https://api.coingecko.com/api/v3
